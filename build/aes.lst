  55:Core/Src/aes.c **** void aes_encrypt_block(const uint8_t rk[176], uint8_t s[16])
  56:Core/Src/aes.c **** {
  57:Core/Src/aes.c ****     /* AddRoundKey 0 */
  58:Core/Src/aes.c ****     for (int i = 0; i < 16; i++) s[i] ^= rk[i];
  59:Core/Src/aes.c **** 
  60:Core/Src/aes.c ****     for (int round = 1; round < 10; round++) {
  61:Core/Src/aes.c ****         /* SubBytes */
  62:Core/Src/aes.c ****         for (int i = 0; i < 16; i++) s[i] = aes_sbox[s[i]];
  63:Core/Src/aes.c ****         /* ShiftRows */
ARM GAS  /tmp/ccndHvKY.s 			page 3


  64:Core/Src/aes.c ****         uint8_t t;
  65:Core/Src/aes.c ****         t = s[1];  s[1] = s[5];  s[5] = s[9];   s[9]  = s[13]; s[13] = t;
  66:Core/Src/aes.c ****         t = s[2];  s[2] = s[10]; s[10] = t;  t = s[6]; s[6] = s[14]; s[14] = t;
  67:Core/Src/aes.c ****         t = s[15]; s[15] = s[11]; s[11] = s[7]; s[7] = s[3];  s[3]  = t;
  68:Core/Src/aes.c ****         /* MixColumns */
  69:Core/Src/aes.c ****         for (int c = 0; c < 4; c++) {
  70:Core/Src/aes.c ****             uint8_t *col = s + c * 4;
  71:Core/Src/aes.c ****             uint8_t a0 = col[0], a1 = col[1], a2 = col[2], a3 = col[3];
  72:Core/Src/aes.c ****             uint8_t h = a0 ^ a1 ^ a2 ^ a3;
  73:Core/Src/aes.c ****             col[0] ^= h ^ xtime(a0 ^ a1);
  74:Core/Src/aes.c ****             col[1] ^= h ^ xtime(a1 ^ a2);
  75:Core/Src/aes.c ****             col[2] ^= h ^ xtime(a2 ^ a3);
  76:Core/Src/aes.c ****             col[3] ^= h ^ xtime(a3 ^ a0);
  77:Core/Src/aes.c ****         }
  78:Core/Src/aes.c ****         /* AddRoundKey */
  79:Core/Src/aes.c ****         for (int i = 0; i < 16; i++) s[i] ^= rk[round * 16 + i];
  80:Core/Src/aes.c ****     }
  81:Core/Src/aes.c ****     /* финальный раунд (без MixColumns) */
  82:Core/Src/aes.c ****     for (int i = 0; i < 16; i++) s[i] = aes_sbox[s[i]];
  83:Core/Src/aes.c ****     uint8_t t;
  84:Core/Src/aes.c ****     t = s[1];  s[1] = s[5];  s[5] = s[9];   s[9]  = s[13]; s[13] = t;
  85:Core/Src/aes.c ****     t = s[2];  s[2] = s[10]; s[10] = t;  t = s[6]; s[6] = s[14]; s[14] = t;
  86:Core/Src/aes.c ****     t = s[15]; s[15] = s[11]; s[11] = s[7]; s[7] = s[3];  s[3]  = t;
  87:Core/Src/aes.c ****     for (int i = 0; i < 16; i++) s[i] ^= rk[160 + i];
  88:Core/Src/aes.c **** }
