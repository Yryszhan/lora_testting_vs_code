  37:Core/Src/aes.c **** void aes_key_expand(const uint8_t key[16], uint8_t rk[176])
  38:Core/Src/aes.c **** {
  39:Core/Src/aes.c ****     memcpy(rk, key, 16);
  40:Core/Src/aes.c ****     uint8_t t[4];
  41:Core/Src/aes.c ****     for (int i = 16; i < 176; i += 4) {
  42:Core/Src/aes.c ****         memcpy(t, rk + i - 4, 4);
  43:Core/Src/aes.c ****         if (i % 16 == 0) {
  44:Core/Src/aes.c ****             uint8_t tmp = t[0];
  45:Core/Src/aes.c ****             t[0] = aes_sbox[t[1]] ^ aes_rcon[i / 16];
  46:Core/Src/aes.c ****             t[1] = aes_sbox[t[2]];
  47:Core/Src/aes.c ****             t[2] = aes_sbox[t[3]];
  48:Core/Src/aes.c ****             t[3] = aes_sbox[tmp];
  49:Core/Src/aes.c ****         }
  50:Core/Src/aes.c ****         for (int j = 0; j < 4; j++)
  51:Core/Src/aes.c ****             rk[i + j] = rk[i - 16 + j] ^ t[j];
  52:Core/Src/aes.c ****     }
  53:Core/Src/aes.c **** }
