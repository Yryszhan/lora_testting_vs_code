 149:Core/Src/main.c **** /* CMAC по сообщению msg[len] ключом key, результат mac[16] */
 150:Core/Src/main.c **** static void aes_cmac(const uint8_t key[16], const uint8_t *msg, int len, uint8_t mac[16])
 151:Core/Src/main.c **** {
 152:Core/Src/main.c ****     uint8_t rk[176];
 153:Core/Src/main.c ****     aes_key_expand(key, rk);
 154:Core/Src/main.c ****     uint8_t k1[16],k2[16];
 155:Core/Src/main.c ****     cmac_subkey(rk,k1,k2);
 156:Core/Src/main.c **** 
 157:Core/Src/main.c ****     int n=(len+15)/16;
 158:Core/Src/main.c ****     int flag_complete;
 159:Core/Src/main.c ****     if(n==0){ n=1; flag_complete=0; }
 160:Core/Src/main.c ****     else flag_complete=(len%16==0);
 161:Core/Src/main.c **** 
 162:Core/Src/main.c ****     uint8_t X[16]={0};
 163:Core/Src/main.c ****     uint8_t M_last[16];
 164:Core/Src/main.c **** 
 165:Core/Src/main.c ****     /* последний блок */
 166:Core/Src/main.c ****     int last_start=(n-1)*16;
 167:Core/Src/main.c ****     if(flag_complete){
ARM GAS  /tmp/ccxe0c4o.s 			page 15


 168:Core/Src/main.c ****         for(int i=0;i<16;i++) M_last[i]=msg[last_start+i]^k1[i];
 169:Core/Src/main.c ****     } else {
 170:Core/Src/main.c ****         int rem=len-last_start;
 171:Core/Src/main.c ****         for(int i=0;i<16;i++){
 172:Core/Src/main.c ****             uint8_t b;
 173:Core/Src/main.c ****             if(i<rem) b=msg[last_start+i];
 174:Core/Src/main.c ****             else if(i==rem) b=0x80;
 175:Core/Src/main.c ****             else b=0x00;
 176:Core/Src/main.c ****             M_last[i]=b^k2[i];
 177:Core/Src/main.c ****         }
 178:Core/Src/main.c ****     }
 179:Core/Src/main.c **** 
 180:Core/Src/main.c ****     /* блоки 0..n-2 */
 181:Core/Src/main.c ****     for(int i=0;i<n-1;i++){
 182:Core/Src/main.c ****         for(int j=0;j<16;j++) X[j]^=msg[i*16+j];
 183:Core/Src/main.c ****         aes_encrypt_block(rk,X);
 184:Core/Src/main.c ****     }
 185:Core/Src/main.c ****     for(int j=0;j<16;j++) X[j]^=M_last[j];
 186:Core/Src/main.c ****     aes_encrypt_block(rk,X);
 187:Core/Src/main.c ****     memcpy(mac,X,16);
 188:Core/Src/main.c **** }
 189:Core/Src/main.c **** 
 190:Core/Src/main.c **** /* ============================================================
 191:Core/Src/main.c ****  *      LoRaWAN: шифрование payload (AES-CTR) + MIC (B0)
 192:Core/Src/main.c ****  * ============================================================ */
 193:Core/Src/main.c **** 
 194:Core/Src/main.c **** /* Шифрование/дешифрование FRMPayload по LoRaWAN (FCntUp в dir=0) */
 195:Core/Src/main.c **** static void lorawan_encrypt_payload(uint8_t *data, int len,
 196:Core/Src/main.c ****                                     const uint8_t appskey[16],
 197:Core/Src/main.c ****                                     const uint8_t devaddr_le[4],
 198:Core/Src/main.c ****                                     uint32_t fcnt)
 199:Core/Src/main.c **** {
 200:Core/Src/main.c ****     uint8_t rk[176];
 201:Core/Src/main.c ****     aes_key_expand(appskey, rk);
 202:Core/Src/main.c ****     int k=(len+15)/16;
 203:Core/Src/main.c ****     for(int i=1;i<=k;i++){
 204:Core/Src/main.c ****         uint8_t A[16]={0x01,0,0,0,0, 0x00, /* dir=0 uplink */
 205:Core/Src/main.c ****                        devaddr_le[0],devaddr_le[1],devaddr_le[2],devaddr_le[3],
 206:Core/Src/main.c ****                        (uint8_t)(fcnt&0xFF),(uint8_t)((fcnt>>8)&0xFF),
 207:Core/Src/main.c ****                        (uint8_t)((fcnt>>16)&0xFF),(uint8_t)((fcnt>>24)&0xFF),
 208:Core/Src/main.c ****                        0x00, (uint8_t)i};
 209:Core/Src/main.c ****         uint8_t S[16];
 210:Core/Src/main.c ****         memcpy(S,A,16);
 211:Core/Src/main.c ****         aes_encrypt_block(rk,S);
 212:Core/Src/main.c ****         int blockstart=(i-1)*16;
 213:Core/Src/main.c ****         int n=len-blockstart; if(n>16) n=16;
 214:Core/Src/main.c ****         for(int j=0;j<n;j++) data[blockstart+j]^=S[j];
 215:Core/Src/main.c ****     }
 216:Core/Src/main.c **** }
 217:Core/Src/main.c **** 
 218:Core/Src/main.c **** /* MIC по LoRaWAN 1.0: B0 || msg, CMAC с NwkSKey, первые 4 байта */
 219:Core/Src/main.c **** static void lorawan_compute_mic(const uint8_t *msg, int len,
 220:Core/Src/main.c ****                                 const uint8_t nwkskey[16],
 221:Core/Src/main.c ****                                 const uint8_t devaddr_le[4],
 222:Core/Src/main.c ****                                 uint32_t fcnt, uint8_t mic[4])
 223:Core/Src/main.c **** {
 224:Core/Src/main.c ****     uint8_t buf[64];
ARM GAS  /tmp/ccxe0c4o.s 			page 16


 225:Core/Src/main.c ****     /* блок B0 */
 226:Core/Src/main.c ****     uint8_t B0[16]={0x49,0,0,0,0, 0x00, /* dir=0 */
 227:Core/Src/main.c ****                     devaddr_le[0],devaddr_le[1],devaddr_le[2],devaddr_le[3],
 228:Core/Src/main.c ****                     (uint8_t)(fcnt&0xFF),(uint8_t)((fcnt>>8)&0xFF),
 229:Core/Src/main.c ****                     (uint8_t)((fcnt>>16)&0xFF),(uint8_t)((fcnt>>24)&0xFF),
 230:Core/Src/main.c ****                     0x00,(uint8_t)len};
 231:Core/Src/main.c ****     memcpy(buf,B0,16);
 232:Core/Src/main.c ****     memcpy(buf+16,msg,len);
 233:Core/Src/main.c ****     uint8_t full[16];
 234:Core/Src/main.c ****     aes_cmac(nwkskey, buf, 16+len, full);
 235:Core/Src/main.c ****     memcpy(mic,full,4);
 236:Core/Src/main.c **** }
 237:Core/Src/main.c **** 
 238:Core/Src/main.c **** /* Собирает готовый LoRaWAN-кадр в out[], возвращает длину */
 239:Core/Src/main.c **** static int lorawan_build_uplink(uint8_t *out, const uint8_t *app_payload,
 240:Core/Src/main.c ****                                 int app_len, uint8_t fport, uint32_t fcnt)
 241:Core/Src/main.c **** {
 242:Core/Src/main.c ****     uint8_t devaddr_le[4]={DEVADDR[3],DEVADDR[2],DEVADDR[1],DEVADDR[0]};
 243:Core/Src/main.c ****     int p=0;
 244:Core/Src/main.c ****     out[p++]=0x40;                 /* MHDR: unconfirmed data up */
 245:Core/Src/main.c ****     out[p++]=devaddr_le[0];        /* DevAddr little-endian */
 246:Core/Src/main.c ****     out[p++]=devaddr_le[1];
 247:Core/Src/main.c ****     out[p++]=devaddr_le[2];
 248:Core/Src/main.c ****     out[p++]=devaddr_le[3];
 249:Core/Src/main.c ****     out[p++]=0x00;                 /* FCtrl */
 250:Core/Src/main.c ****     out[p++]=(uint8_t)(fcnt&0xFF); /* FCnt little-endian */
 251:Core/Src/main.c ****     out[p++]=(uint8_t)((fcnt>>8)&0xFF);
 252:Core/Src/main.c ****     out[p++]=fport;                /* FPort */
 253:Core/Src/main.c **** 
 254:Core/Src/main.c ****     /* копируем payload и шифруем его на месте */
 255:Core/Src/main.c ****     uint8_t enc[32];
 256:Core/Src/main.c ****     memcpy(enc, app_payload, app_len);
 257:Core/Src/main.c ****     lorawan_encrypt_payload(enc, app_len, APPSKEY, devaddr_le, fcnt);
 258:Core/Src/main.c ****     memcpy(out+p, enc, app_len);
 259:Core/Src/main.c ****     p+=app_len;
 260:Core/Src/main.c **** 
 261:Core/Src/main.c ****     /* MIC по всему, что собрали (MHDR..FRMPayload) */
 262:Core/Src/main.c ****     uint8_t mic[4];
 263:Core/Src/main.c ****     lorawan_compute_mic(out, p, NWKSKEY, devaddr_le, fcnt, mic);
 264:Core/Src/main.c ****     memcpy(out+p, mic, 4);
 265:Core/Src/main.c ****     p+=4;
 266:Core/Src/main.c **** 
 267:Core/Src/main.c ****     return p;  /* итоговая длина кадра */
 268:Core/Src/main.c **** }
