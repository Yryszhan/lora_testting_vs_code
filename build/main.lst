  60:Core/Src/main.c **** static void sx_radio_config(void)
  61:Core/Src/main.c **** {
  62:Core/Src/main.c ****     uint8_t rx[10] = {0};
  63:Core/Src/main.c ****     { uint8_t t[2]={0x80,0x00}; sx_cmd(t,rx,2); HAL_Delay(5); }
  64:Core/Src/main.c ****     { uint8_t t[2]={0x89,0x7F}; sx_cmd(t,rx,2); HAL_Delay(20); }
  65:Core/Src/main.c ****     { uint8_t t[1]={0x07}; sx_cmd(t,rx,1); HAL_Delay(5); }
  66:Core/Src/main.c **** 
  67:Core/Src/main.c ****     // Регулятор LDO
  68:Core/Src/main.c ****     { uint8_t t[2]={0x96,0x00}; sx_cmd(t,rx,2); HAL_Delay(5); }
  69:Core/Src/main.c ****     // DIO2 управляет RF-свитчем
ARM GAS  /tmp/ccjrlmlE.s 			page 4


  70:Core/Src/main.c ****     { uint8_t t[2]={0x9D,0x01}; sx_cmd(t,rx,2); HAL_Delay(5); }
  71:Core/Src/main.c ****     // CalibrateImage 863-870
  72:Core/Src/main.c ****     { uint8_t t[3]={0x98,0xD7,0xDB}; sx_cmd(t,rx,3); HAL_Delay(5); }
  73:Core/Src/main.c ****     // PacketType LoRa
  74:Core/Src/main.c ****     { uint8_t t[2]={0x8A,0x01}; sx_cmd(t,rx,2); HAL_Delay(5); }
  75:Core/Src/main.c **** 
  76:Core/Src/main.c ****     // Частота: ТОЧНО 868.100 МГц (было 868.135, смещение убрано)
  77:Core/Src/main.c ****     { uint8_t t[5]={0x86,0x36,0x40,0x3D,0x60}; sx_cmd(t,rx,5); HAL_Delay(5); }
  78:Core/Src/main.c **** 
  79:Core/Src/main.c ****     // PA config +22 dBm
  80:Core/Src/main.c ****     { uint8_t t[5]={0x95,0x04,0x07,0x00,0x01}; sx_cmd(t,rx,5); HAL_Delay(5); }
  81:Core/Src/main.c ****     // TX params 22 dBm, ramp 200us
  82:Core/Src/main.c ****     { uint8_t t[3]={0x8E,22,0x04}; sx_cmd(t,rx,3); HAL_Delay(5); }
  83:Core/Src/main.c **** 
  84:Core/Src/main.c ****     // Модуляция SF12 BW125 CR4/5 LDRO on
  85:Core/Src/main.c ****     { uint8_t t[5]={0x8B,0x0C,0x04,0x01,0x01}; sx_cmd(t,rx,5); HAL_Delay(5); }
  86:Core/Src/main.c ****     // Синхрослово LoRaWAN 0x3444
  87:Core/Src/main.c ****     { uint8_t t[5]={0x0D,0x07,0x40,0x34,0x44}; sx_cmd(t,rx,5); HAL_Delay(5); }
  88:Core/Src/main.c **** }
  89:Core/Src/main.c **** 
  90:Core/Src/main.c **** static void sx_send_packet(void)
  91:Core/Src/main.c **** {
  92:Core/Src/main.c ****     uint8_t rx[10] = {0};
  93:Core/Src/main.c ****     { uint8_t t[2]={0x80,0x00}; sx_cmd(t,rx,2); HAL_Delay(5); }
  94:Core/Src/main.c ****     { uint8_t t[3]={0x8F,0x00,0x00}; sx_cmd(t,rx,3); HAL_Delay(5); }
  95:Core/Src/main.c ****     { uint8_t t[7]={0x8C,0x00,0x08,0x00,15,0x01,0x00}; sx_cmd(t,rx,7); HAL_Delay(5); }
  96:Core/Src/main.c ****     {
  97:Core/Src/main.c ****         uint8_t payload[15] = {0x40,0x53,0x6b,0x88,0x00,0x00,0x00,0x00,
  98:Core/Src/main.c ****                                0x01,'H','I',0x00,0x00,0x00,0x00};
  99:Core/Src/main.c ****         uint8_t wr[1]={0x0E}; uint8_t addr[1]={0x00}; uint8_t d[16]={0};
 100:Core/Src/main.c ****         busy();
 101:Core/Src/main.c ****         HAL_GPIO_WritePin(NSS_GPIO_Port, NSS_Pin, GPIO_PIN_RESET);
 102:Core/Src/main.c ****         HAL_SPI_TransmitReceive(&hspi1, wr,   d, 1, 100);
 103:Core/Src/main.c ****         HAL_SPI_TransmitReceive(&hspi1, addr, d, 1, 100);
 104:Core/Src/main.c ****         HAL_SPI_TransmitReceive(&hspi1, payload, d, 15, 100);
 105:Core/Src/main.c ****         HAL_GPIO_WritePin(NSS_GPIO_Port, NSS_Pin, GPIO_PIN_SET);
 106:Core/Src/main.c ****         HAL_Delay(5);
 107:Core/Src/main.c ****     }
 108:Core/Src/main.c ****     { uint8_t t[3]={0x02,0xFF,0xFF}; sx_cmd(t,rx,3); HAL_Delay(5); }
 109:Core/Src/main.c ****     { uint8_t t[4]={0x83,0x00,0x00,0x00}; sx_cmd(t,rx,4); }
 110:Core/Src/main.c ****     HAL_Delay(2);
 111:Core/Src/main.c ****     mode_after_tx = sx_chipmode();
 112:Core/Src/main.c ****     tx_reached = (mode_after_tx == 0x06) ? 1 : 0;
 113:Core/Src/main.c ****     HAL_Delay(2000);
 114:Core/Src/main.c ****     { uint8_t t[4]={0x17,0x00,0x00,0x00}; uint8_t r[4]={0};
 115:Core/Src/main.c ****       sx_cmd(t,r,4); err_lsb = r[3]; }
 116:Core/Src/main.c ****     tx_count++;
 117:Core/Src/main.c **** }
