  44:Core/Src/main.c **** static uint8_t sx_chipmode(void)
  45:Core/Src/main.c **** {
  46:Core/Src/main.c ****     uint8_t tx[2] = {0xC0, 0x00};
  47:Core/Src/main.c ****     uint8_t rx[2] = {0};
  48:Core/Src/main.c ****     sx_cmd(tx, rx, 2);
  49:Core/Src/main.c ****     return (rx[1] >> 4) & 0x7;
  50:Core/Src/main.c **** }
  51:Core/Src/main.c **** 
  52:Core/Src/main.c **** static uint8_t sx_readreg(uint16_t addr)
  53:Core/Src/main.c **** {
  54:Core/Src/main.c ****     uint8_t tx[5] = {0x1D, (addr>>8)&0xFF, addr&0xFF, 0x00, 0x00};
  55:Core/Src/main.c ****     uint8_t rx[5] = {0};
  56:Core/Src/main.c ****     sx_cmd(tx, rx, 5);
  57:Core/Src/main.c ****     return rx[4];
  58:Core/Src/main.c **** }
