  72:Core/Src/main.c **** /* Расширение ключа: 11 round-ключей по 16 байт */
  73:Core/Src/main.c **** static void aes_key_expand(const uint8_t key[16], uint8_t rk[176])
  74:Core/Src/main.c **** {
  75:Core/Src/main.c ****     memcpy(rk, key, 16);
  76:Core/Src/main.c ****     uint8_t t[4];
  77:Core/Src/main.c ****     for (int i = 16; i < 176; i += 4) {
  78:Core/Src/main.c ****         memcpy(t, rk + i - 4, 4);
  79:Core/Src/main.c ****         if (i % 16 == 0) {
  80:Core/Src/main.c ****             uint8_t tmp = t[0];
  81:Core/Src/main.c ****             t[0] = aes_sbox[t[1]] ^ aes_rcon[i/16];
  82:Core/Src/main.c ****             t[1] = aes_sbox[t[2]];
  83:Core/Src/main.c ****             t[2] = aes_sbox[t[3]];
  84:Core/Src/main.c ****             t[3] = aes_sbox[tmp];
  85:Core/Src/main.c ****         }
  86:Core/Src/main.c ****         for (int j = 0; j < 4; j++)
  87:Core/Src/main.c ****             rk[i+j] = rk[i-16+j] ^ t[j];
  88:Core/Src/main.c ****     }
  89:Core/Src/main.c **** }
